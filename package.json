{
  "name": "vortex-file-manager",
  "version": "1.0.0",
  "description": "Modern, fast, and powerful file manager built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:all": "electron-builder -mwl",
    "package": "electron-builder --win --publish never",
    "dist": "electron-builder"
  },
  "keywords": [
    "file-manager",
    "electron",
    "vortex",
    "file-explorer",
    "windows"
  ],
  "author": "Vortex Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "adm-zip": "^0.5.10",
    "chokidar": "^3.5.3",
    "fast-glob": "^3.3.2",
    "fluent-ffmpeg": "^2.1.3",
    "node-7z": "^3.0.0",
    "pdfjs-dist": "^3.11.174"
  },
  "build": {
    "appId": "com.vortex.filemanager",
    "productName": "Vortex File Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/.bin/**/*"
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**/*",
      "node_modules/@ffprobe-installer/**/*",
      "node_modules/fluent-ffmpeg/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icons/app-icon.ico",
      "fileAssociations": [
        {
          "ext": [
            "mp4",
            "mkv",
            "avi",
            "mov",
            "wmv",
            "webm",
            "m4v",
            "flv",
            "ogv",
            "3gp"
          ],
          "name": "Video File",
          "description": "Play with Vortex Player",
          "role": "Viewer"
        },
        {
          "ext": [
            "mp3",
            "wav",
            "flac",
            "ogg",
            "m4a",
            "aac",
            "wma"
          ],
          "name": "Audio File",
          "description": "Play with Vortex Player",
          "role": "Viewer"
        },
        {
          "ext": [
            "pdf"
          ],
          "name": "PDF Document",
          "description": "Open with Vortex PDF Reader",
          "role": "Viewer"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": "Vortex",
      "shortcutName": "Vortex File Manager",
      "installerIcon": "src/assets/icons/app-icon.ico",
      "uninstallerIcon": "src/assets/icons/app-icon.ico",
      "warningsAsErrors": false,
      "include": "installer.nsh"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icons/app-icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "src/assets/icons/app-icon.png",
      "category": "Utility"
    }
  }
}
